<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>a3f7c2d1-4e89-4b6a-9f12-8c3d5e7a1b04</Id>
  <Version>1.0.0.2</Version>
  <ProviderName>Belmond</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Bella - Belmond Assistant" />
  <Description DefaultValue="Generate a reply to this email using Bella, Belmond's AI assistant" />

  <IconUrl DefaultValue="https://bel-prd-vision-prj.web.app/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://bel-prd-vision-prj.web.app/icon-80.png" />

  <SupportUrl DefaultValue="https://www.belmond.com" />

  <AppDomains>
    <AppDomain>https://bel-prd-vision-prj.web.app</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://bel-prd-vision-prj.web.app/index.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <FunctionFile resid="CommandsFile.Url" />

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel" />

                <!-- Panel mode: opens the task pane (auto-triggers the API call) -->
                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>

                <!-- Inject mode: no task pane, calls API silently then opens reply -->
                <Control xsi:type="Button" id="msgReadInjectButton">
                  <Label resid="InjectButton.Label" />
                  <Supertip>
                    <Title resid="InjectButton.Label" />
                    <Description resid="InjectButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>bellaReply</FunctionName>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://bel-prd-vision-prj.web.app/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://bel-prd-vision-prj.web.app/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://bel-prd-vision-prj.web.app/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="CommandsFile.Url" DefaultValue="https://bel-prd-vision-prj.web.app/commands.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://bel-prd-vision-prj.web.app/index.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="Bella" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Reply with Bella" />
        <bt:String id="InjectButton.Label" DefaultValue="Reply with Bella (Quick)" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Bella panel to generate a reply to this email" />
        <bt:String id="InjectButton.Tooltip" DefaultValue="Generate a reply with Bella and open it as a draft reply" />
      </bt:LongStrings>
    </Resources>

    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.10">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <Runtimes>
            <Runtime resid="LaunchEventsFile.Url" lifetime="short" />
          </Runtimes>
          <DesktopFormFactor>
            <FunctionFile resid="CommandsFile.Url" />

            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadGroup">
                  <Label resid="GroupLabel" />

                  <!-- Panel mode: opens the task pane (auto-triggers the API call) -->
                  <Control xsi:type="Button" id="msgReadOpenPaneButton">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>

                  <!-- Inject mode: no task pane, calls API silently then opens reply -->
                  <Control xsi:type="Button" id="msgReadInjectButton">
                    <Label resid="InjectButton.Label" />
                    <Supertip>
                      <Title resid="InjectButton.Label" />
                      <Description resid="InjectButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>bellaReply</FunctionName>
                    </Action>
                  </Control>

                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- Event-based activation: inject draft when reply form opens -->
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageCompose" />
              </LaunchEvents>
              <SourceLocation resid="LaunchEventsFile.Url" />
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://bel-prd-vision-prj.web.app/icon-16.png" />
          <bt:Image id="Icon.32x32" DefaultValue="https://bel-prd-vision-prj.web.app/icon-32.png" />
          <bt:Image id="Icon.80x80" DefaultValue="https://bel-prd-vision-prj.web.app/icon-80.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="CommandsFile.Url" DefaultValue="https://bel-prd-vision-prj.web.app/commands.html" />
          <bt:Url id="Taskpane.Url" DefaultValue="https://bel-prd-vision-prj.web.app/index.html" />
          <bt:Url id="LaunchEventsFile.Url" DefaultValue="https://bel-prd-vision-prj.web.app/launchEvents.html" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Bella" />
          <bt:String id="TaskpaneButton.Label" DefaultValue="Reply with Bella" />
          <bt:String id="InjectButton.Label" DefaultValue="Reply with Bella (Quick)" />
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the Bella panel to generate a reply to this email" />
          <bt:String id="InjectButton.Tooltip" DefaultValue="Generate a reply with Bella and open it as a draft reply" />
        </bt:LongStrings>
      </Resources>

      <WebApplicationInfo>
        <Id>e8919706-c411-4da6-9da5-5f1b1c836cfe</Id>
        <Resource>api://bel-prd-vision-prj.web.app/e8919706-c411-4da6-9da5-5f1b1c836cfe</Resource>
        <Scopes>
          <Scope>openid</Scope>
          <Scope>profile</Scope>
          <Scope>email</Scope>
        </Scopes>
      </WebApplicationInfo>

    </VersionOverrides>

  </VersionOverrides>

</OfficeApp>
