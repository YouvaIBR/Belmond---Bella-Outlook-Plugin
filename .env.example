# ── Entra ID (Azure AD) ────────────────────────────────────────────────────────
# App Registration client ID (from Entra ID → App registrations)
VITE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Tenant ID
VITE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── n8n ────────────────────────────────────────────────────────────────────────
# Webhook URL — the n8n webhook secured with JWT auth
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bella

# Workday data URL — GET endpoint returning the requisition option lists (Bearer auth)
VITE_N8N_WORKDAY_DATA_URL=https://your-n8n-instance.com/webhook/bella-workday-data

# Workday submit URL — POST endpoint to create + submit a requisition (multipart, Bearer auth)
VITE_N8N_WORKDAY_SUBMIT_URL=https://your-n8n-instance.com/webhook/bella-workday-submit