# ── Entra ID (Azure AD) ────────────────────────────────────────────────────────
# App Registration client ID (from Entra ID → App registrations)
VITE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Tenant ID
VITE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── n8n ────────────────────────────────────────────────────────────────────────
# Webhook URL — the n8n webhook secured with JWT auth
VITE_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/bella